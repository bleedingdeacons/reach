# Composer dependencies. A single rule, matching every other plugin in the
# suite. This file previously enumerated 1752 individual vendor paths, which
# is why eight files slipped through and ended up tracked: psr/container's
# source and a regenerated .phpunit.result.cache.
/vendor/

# Regenerated on every run; an untracked cache file left the working tree
# looking dirty, which was tripping the version-bump "altered" check.
.phpunit.result.cache
/.phpunit.cache/

/build/
