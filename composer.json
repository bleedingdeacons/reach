{
    "name": "bleeding-deacons/reach",
    "description": "Public-facing front end for finding 12th-step members: OAuth email verification and a mobile-first finder UI.",
    "type": "wordpress-plugin",
    "license": "MIT (Modified)",
    "authors": [
        {
            "name": "The Bleeding Deacons"
        }
    ],
    "require": {
        "php": ">=8.1",
        "ext-openssl": "*",
        "ext-json": "*"
    },
    "autoload": {
        "psr-4": {
            "Reach\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Reach\\Tests\\": "tests/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    },
    "scripts": {
        "test": "phpunit",
        "build": "php build.php build:production",
        "build:production": "php build.php build:production",
        "build:dev": "php build.php build:dev",
        "build:clean": "php build.php clean",
        "phpstan": "phpstan analyse --memory-limit=1G"
    },
    "require-dev": {
        "phpstan/phpstan": "^2.0",
        "phpunit/phpunit": "^10.0",
        "psr/container": "^2.0",
        "szepeviktor/phpstan-wordpress": "^2.0"
    }
}
